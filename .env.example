# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/reflex

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Encryption (for BYO API keys, GitHub tokens)
ENCRYPTION_KEY=your-32-byte-hex-key

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Credits
FREE_SIGNUP_CREDITS=20
ANONYMOUS_CREDITS_PER_IP=5
CREDITS_PER_ASSISTANT_CALL=1

# Tier 1 validator (Mac Mini sidecar, reached over Tailscale)
# Wrapper degrades to { ok: null, skipped: true } if any of these are missing,
# so it's safe to leave them blank in dev.
VALIDATOR_URL=http://100.82.195.40:8080
VALIDATOR_TOKEN=

# Tailscale userspace HTTP proxy. Set on Railway (along with TS_AUTHKEY,
# which start.sh consumes) so the wrapper's fetch() routes via the local
# Tailscale daemon. Leave empty in dev.
VALIDATOR_HTTP_PROXY=

# Ephemeral, reusable, tag:railway auth key from
# https://login.tailscale.com/admin/settings/keys — only consumed by
# start.sh inside the Railway container. Not needed locally.
TS_AUTHKEY=
